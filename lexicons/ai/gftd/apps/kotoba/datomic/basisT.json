{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.datomic.basisT",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Return the Datomic basis transaction CID for a Kotoba distributed Datom graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph"],
          "properties": {
            "graph": { "type": "string" },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "presentation": { "type": "unknown" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph"],
          "properties": {
            "graph": { "type": "string" },
            "basis_t": { "type": "string" }
          }
        }
      }
    }
  }
}
