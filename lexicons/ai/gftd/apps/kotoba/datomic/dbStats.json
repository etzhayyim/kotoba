{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.datomic.dbStats",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Return Datomic-style statistics for a Kotoba distributed Datom graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph"],
          "properties": {
            "graph": { "type": "string" },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "presentation": { "type": "unknown" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "graph",
            "datom_count",
            "history_datom_count",
            "entity_count",
            "attribute_count",
            "tx_count"
          ],
          "properties": {
            "graph": { "type": "string" },
            "basis_t": { "type": "string" },
            "datom_count": { "type": "integer", "minimum": 0 },
            "history_datom_count": { "type": "integer", "minimum": 0 },
            "entity_count": { "type": "integer", "minimum": 0 },
            "attribute_count": { "type": "integer", "minimum": 0 },
            "tx_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
