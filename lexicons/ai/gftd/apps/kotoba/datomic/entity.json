{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.datomic.entity",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Return Datomic entity data for a Kotoba distributed Datom graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "entity"],
          "properties": {
            "graph": { "type": "string" },
            "entity": { "type": "string" },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "presentation": { "type": "unknown" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": { "type": "unknown" }
      }
    }
  }
}
