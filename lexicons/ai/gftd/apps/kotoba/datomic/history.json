{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.datomic.history",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Return Datomic history Datoms for a Kotoba graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph"],
          "properties": {
            "graph": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "presentation": { "type": "unknown" },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "limit": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "datom_count", "datoms"],
          "properties": {
            "graph": { "type": "string" },
            "basis_t": { "type": "string" },
            "datom_count": { "type": "integer", "minimum": 0 },
            "datoms": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["e", "a", "v_edn", "t", "added"],
                "properties": {
                  "e": { "type": "string" },
                  "a": { "type": "string" },
                  "v_edn": { "type": "string" },
                  "t": { "type": "string" },
                  "added": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}
