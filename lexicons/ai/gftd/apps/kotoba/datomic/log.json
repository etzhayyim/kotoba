{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.datomic.log",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Return a Datomic-style transaction log for a Kotoba graph from the distributed IPNS head.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph"],
          "properties": {
            "graph": { "type": "string" },
            "start": { "type": "string" },
            "end": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "presentation": { "type": "unknown" },
            "limit": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "tx_count", "txes"],
          "properties": {
            "graph": { "type": "string" },
            "basis_t": { "type": "string" },
            "tx_count": { "type": "integer", "minimum": 0 },
            "txes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["tx_cid", "datom_count", "datoms"],
                "properties": {
                  "tx_cid": { "type": "string" },
                  "datom_count": { "type": "integer", "minimum": 0 },
                  "datoms": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["e", "a", "v_edn", "t", "added"],
                      "properties": {
                        "e": { "type": "string" },
                        "a": { "type": "string" },
                        "v_edn": { "type": "string" },
                        "t": { "type": "string" },
                        "added": { "type": "boolean" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
