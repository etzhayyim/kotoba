{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.datomic.pull",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Datomic pull against a Kotoba distributed Datom graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "entity"],
          "properties": {
            "graph": { "type": "string" },
            "entity": { "type": "string" },
            "pattern_edn": { "type": "string" },
            "as_of": { "type": "string" },
            "since": { "type": "string" },
            "cacao_b64": { "type": "string" },
            "presentation": { "type": "unknown" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "entity", "entity_edn", "datom_count", "datoms"],
          "properties": {
            "graph": { "type": "string" },
            "entity": { "type": "string" },
            "basis_t": { "type": "string" },
            "entity_edn": { "type": "string" },
            "datom_count": { "type": "integer", "minimum": 0 },
            "datoms": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["e", "a", "v_edn", "t", "added"],
                "properties": {
                  "e": { "type": "string" },
                  "a": { "type": "string" },
                  "v_edn": { "type": "string" },
                  "t": { "type": "string" },
                  "added": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}
