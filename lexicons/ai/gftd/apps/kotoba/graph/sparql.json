{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.graph.sparql",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Execute SPARQL SELECT, ASK, DESCRIBE, or CONSTRUCT over a Kotoba distributed Datom graph.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["query"],
          "properties": {
            "query": { "type": "string" },
            "graph": { "type": "string" },
            "cacaoB64": { "type": "string" },
            "limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
            "maxHops": { "type": "integer", "minimum": 0, "maximum": 16 }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["ok", "form", "elapsedMs"],
          "properties": {
            "ok": { "type": "boolean" },
            "form": {
              "type": "string",
              "knownValues": ["select", "ask", "describe", "construct"]
            },
            "result": { "type": "boolean" },
            "count": { "type": "integer", "minimum": 0 },
            "maxHops": { "type": "integer", "minimum": 0, "maximum": 16 },
            "elapsedMs": { "type": "integer", "minimum": 0 },
            "quads": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["graph", "subject", "predicate", "object"],
                "properties": {
                  "graph": { "type": "string" },
                  "subject": { "type": "string" },
                  "predicate": { "type": "string" },
                  "object": {
                    "type": "object",
                    "properties": {
                      "cid": { "type": "string" },
                      "text": { "type": "string" },
                      "int": { "type": "integer" },
                      "float": { "type": "number" },
                      "bool": { "type": "boolean" },
                      "raw": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
