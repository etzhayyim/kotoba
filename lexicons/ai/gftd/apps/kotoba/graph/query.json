{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.graph.query",
  "defs": {
    "main": {
      "type": "query",
      "description": "Read SPO quads from a Kotoba graph using graph:query capability for private graphs.",
      "parameters": {
        "type": "params",
        "required": ["graph"],
        "properties": {
          "graph": { "type": "string" },
          "subject": { "type": "string" },
          "predicate": { "type": "string" },
          "rules": { "type": "string" },
          "cacao_b64": { "type": "string" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 1000 }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["graph", "count", "quads"],
          "properties": {
            "graph": { "type": "string" },
            "count": { "type": "integer", "minimum": 0 },
            "limit": { "type": "integer", "minimum": 1, "maximum": 1000 },
            "truncated": { "type": "boolean" },
            "note": { "type": "string" },
            "quads": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["graph", "subject", "predicate", "object"],
                "properties": {
                  "graph": {
                    "type": "array",
                    "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                  },
                  "subject": {
                    "type": "array",
                    "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                  },
                  "predicate": { "type": "string" },
                  "object": { "type": "object" }
                }
              }
            }
          }
        }
      }
    }
  }
}
