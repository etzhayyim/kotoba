{
  "lexicon": 1,
  "id": "ai.gftd.apps.kotoba.attest.claim",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Issue a Kotoba attestation as a W3C Verifiable Credential projected to Datoms.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["entity_did", "claim_type", "attester_did", "stake_mkoto"],
          "properties": {
            "entity_did": { "type": "string" },
            "claim_type": { "type": "string" },
            "attester_did": { "type": "string" },
            "stake_mkoto": { "type": "integer", "minimum": 0 },
            "evidence": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "status",
            "claim_cid",
            "credential_cid",
            "credential_id",
            "credential_type",
            "credential_wire_format",
            "credential_data_model",
            "commit_cid",
            "ipns_name",
            "ipns_sequence"
          ],
          "properties": {
            "status": { "type": "string", "knownValues": ["attested"] },
            "claim_cid": { "type": "string" },
            "credential_cid": { "type": "string" },
            "credential_id": { "type": "string" },
            "credential_type": { "type": "string" },
            "credential_wire_format": { "type": "string" },
            "credential_data_model": { "type": "string" },
            "commit_cid": { "type": "string" },
            "ipns_name": { "type": "string" },
            "ipns_sequence": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
